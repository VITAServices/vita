# Copy this file to .env (for local testing with `vercel dev`) and fill in real values.
# In production, these are set as Environment Variables in the Vercel project dashboard
# (Project > Settings > Environment Variables) -- never committed to the repo.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

RESEND_API_KEY=
# Optional: only set this once the vitasoinsetservices.com domain is verified in Resend.
# Until then, leave unset and the function falls back to Resend's shared sending domain.
NOTIFY_FROM_EMAIL="VITA Website <onboarding@resend.dev>"

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
